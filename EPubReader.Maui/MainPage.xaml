<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EPubReader.Maui.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:EPubReader.Maui"
    NavigationPage.HasNavigationBar="False">
    <ContentPage.Resources>
        <local:InvertBoolConverter x:Key="InvertBoolConverter" />
        <local:BitmapConverter x:Key="BitmapConverter" />
    </ContentPage.Resources>
    <!--  Outer grid: content row + bottom bar row (height set in code-behind on Android)  -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition x:Name="BottomBarRow" Height="0" />
        </Grid.RowDefinitions>
        <!--  ═══ Main content row ═══  -->
        <Grid x:Name="MainContentGrid" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <!--  Width set to 0 on Android in code-behind  -->
                <ColumnDefinition x:Name="SidebarColumn" Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  ═══ Left panel: Fandoms sidebar ═══  -->
            <Grid
                x:Name="SidebarPanel"
                Grid.Column="0"
                Padding="16,24,16,16"
                BackgroundColor="{AppThemeBinding Dark=#1a1a1a,
                                                  Light=#f0f0f0}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Label
                    Margin="8,0,0,20"
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="Fandoms"
                    TextColor="{AppThemeBinding Dark=White,
                                                Light=Black}" />
                <!--  Fandom list  -->
                <CollectionView
                    x:Name="FandomList"
                    Grid.Row="1"
                    BackgroundColor="Transparent"
                    SelectionChanged="FandomList_SelectionChanged"
                    SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="6" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border
                                Margin="10"
                                Padding="10"
                                BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                  Light=#ffffff}"
                                Stroke="{AppThemeBinding Dark=#3a3a3a,
                                                         Light=#e0e0e0}"
                                StrokeShape="RoundRectangle 6"
                                StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <DropGestureRecognizer
                                        AllowDrop="True"
                                        DragLeave="Fandom_DragLeave"
                                        DragOver="Fandom_DragOver"
                                        Drop="Fandom_Drop" />
                                </Border.GestureRecognizers>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding .}"
                                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                                Light=#555555}"
                                    VerticalOptions="Center" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <!--  Add fandom  -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Padding="0,12,0,0"
                    Spacing="8">
                    <Label
                        Margin="2,0,0,0"
                        FontSize="12"
                        Text="Add Fandom"
                        TextColor="{AppThemeBinding Dark=#888888,
                                                    Light=#999999}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            x:Name="NewFandomInput"
                            BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                              Light=#ffffff}"
                            Completed="NewFandomInput_Completed"
                            Placeholder="New fandom..."
                            TextColor="{AppThemeBinding Dark=White,
                                                        Light=Black}" />
                        <Button
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Padding="0"
                            BackgroundColor="#E50914"
                            Clicked="AddFandom_Click"
                            CornerRadius="4"
                            HeightRequest="36"
                            Text="+"
                            TextColor="White"
                            WidthRequest="36" />
                    </Grid>
                </VerticalStackLayout>
                <!--  Settings button  -->
                <Button
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="10"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    Clicked="Settings_Click"
                    Text="⚙  Settings"
                    TextColor="{AppThemeBinding Dark=#888888,
                                                Light=#999999}" />
            </Grid>
            <!--  Sidebar border  -->
            <BoxView
                x:Name="SidebarBorder"
                Grid.Column="0"
                BackgroundColor="{AppThemeBinding Dark=#333333,
                                                  Light=#dddddd}"
                HorizontalOptions="End"
                WidthRequest="1" />
            <!--  ═══ Right panel ═══  -->
            <Grid Grid.Column="1" Padding="28,24,28,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Label
                    x:Name="SelectedFandomHeader"
                    Margin="0,0,0,4"
                    FontAttributes="Bold"
                    FontSize="26"
                    Text="Select a fandom"
                    TextColor="{AppThemeBinding Dark=White,
                                                Light=Black}" />
                <Label
                    x:Name="BookCountText"
                    Grid.Row="1"
                    Margin="0,0,0,20"
                    FontSize="13"
                    Text=""
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}" />

                <!--  Category sections — virtualised  -->
                <CollectionView
                    x:Name="CategorySections"
                    Grid.Row="2"
                    ItemsLayout="VerticalList" />





                <!--  Description panel  -->
                <Border
                    x:Name="DescriptionPanel"
                    Grid.Row="3"
                    Margin="0,12,0,0"
                    Padding="20,16"
                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                      Light=#ffffff}"
                    HeightRequest="240"
                    IsVisible="False"
                    Stroke="{AppThemeBinding Dark=#3a3a3a,
                                             Light=#e0e0e0}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <HorizontalStackLayout Margin="0,0,0,6" Spacing="12">
                            <Label
                                x:Name="SelectedBookTitle"
                                FontAttributes="Bold"
                                FontSize="18"
                                TextColor="{AppThemeBinding Dark=White,
                                                            Light=Black}" />
                            <Border
                                Padding="8,2"
                                BackgroundColor="{AppThemeBinding Dark=#3a3a3a,
                                                                  Light=#e8e8e8}"
                                StrokeShape="RoundRectangle 3"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                                <Label
                                    x:Name="SelectedBookType"
                                    CharacterSpacing="3"
                                    FontSize="10"
                                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                                Light=#555555}" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label
                            x:Name="SelectedBookAuthor"
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            FontSize="13"
                            TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                        Light=#555555}" />
                        <ScrollView Grid.Row="2">
                            <Label
                                x:Name="SelectedBookDescription"
                                FontSize="13"
                                LineBreakMode="WordWrap"
                                TextColor="{AppThemeBinding Dark=#cccccc,
                                                            Light=#333333}" />
                        </ScrollView>


                        <!--  Buttons row — normal actions / category edit toggled  -->
                        <Grid Grid.Row="3" Margin="0,8,0,0">

                            <!--  Normal action buttons (default visible)  -->
                            <Grid x:Name="ActionButtonsRow" ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                                <Button
                                    Grid.Column="0"
                                    Padding="12,0"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#e8e8e8}"
                                    Clicked="OpenBook_Click"
                                    CornerRadius="4"
                                    Text="▶  Read"
                                    TextColor="{AppThemeBinding Dark=White,
                                                                Light=Black}" />
                                <Button
                                    x:Name="SendToKindleButton"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#e8e8e8}"
                                    Clicked="SendToKindle_Click"
                                    CornerRadius="4"
                                    Text="📨  Kindle"
                                    TextColor="{AppThemeBinding Dark=White,
                                                                Light=Black}" />
                                <Button
                                    x:Name="MarkReadButton"
                                    Grid.Column="2"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#e8e8e8}"
                                    Clicked="MarkRead_Click"
                                    CornerRadius="4"
                                    Text="✓ Read"
                                    TextColor="{AppThemeBinding Dark=White,
                                                                Light=Black}" />
                                <Button
                                    x:Name="CategoryToggleButton"
                                    Grid.Column="3"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#e8e8e8}"
                                    Clicked="CategoryToggle_Click"
                                    CornerRadius="4"
                                    Text="✏  Category"
                                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                                Light=#555555}" />
                            </Grid>

                            <!--  Category edit row (hidden until ✏ tapped)  -->
                            <Grid
                                x:Name="CategoryEditRow"
                                ColumnDefinitions="*,Auto"
                                IsVisible="False">
                                <Entry
                                    x:Name="CategoryInput"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#ffffff}"
                                    FontSize="13"
                                    Placeholder="Category..."
                                    TextChanged="CategoryInput_TextChanged"
                                    TextColor="{AppThemeBinding Dark=White,
                                                                Light=Black}"
                                    Unfocused="CategoryInput_Unfocused" />
                                <Button
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    BackgroundColor="#E50914"
                                    Clicked="SaveCategory_Click"
                                    CornerRadius="4"
                                    Text="Save"
                                    TextColor="White" />

                                <!--  Autocomplete dropdown  -->
                                <Border
                                    x:Name="CategorySuggestionsBorder"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="0,40,0,0"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#ffffff}"
                                    IsVisible="False"
                                    MaximumHeightRequest="160"
                                    Stroke="{AppThemeBinding Dark=#444444,
                                                             Light=#cccccc}"
                                    StrokeShape="RoundRectangle 4"
                                    StrokeThickness="1"
                                    VerticalOptions="Start"
                                    ZIndex="10">
                                    <CollectionView
                                        x:Name="CategorySuggestions"
                                        BackgroundColor="Transparent"
                                        SelectionChanged="CategorySuggestion_SelectionChanged"
                                        SelectionMode="Single">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Label
                                                    Padding="10,8"
                                                    FontSize="13"
                                                    Text="{Binding .}"
                                                    TextColor="{AppThemeBinding Dark=White,
                                                                                Light=Black}" />
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Border>
                            </Grid>

                        </Grid>


                    </Grid>
                </Border>

            </Grid>
        </Grid>
        <!--  ═══ Android Bottom Bar ═══  -->
        <Grid
            x:Name="AndroidBottomBar"
            Grid.Row="1"
            BackgroundColor="{AppThemeBinding Dark=#1a1a1a,
                                              Light=#f0f0f0}"
            IsVisible="False">
            <BoxView
                BackgroundColor="{AppThemeBinding Dark=#333333,
                                                  Light=#dddddd}"
                HeightRequest="1"
                VerticalOptions="Start" />
            <Grid Padding="0,4,0,4" ColumnDefinitions="*,*,*">
                <Button
                    x:Name="BottomBarFandomsButton"
                    Grid.Column="0"
                    Padding="0"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    Clicked="BottomBarFandoms_Click"
                    FontSize="13"
                    Text="📚  Fandoms"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}" />
                <Button
                    Grid.Column="1"
                    Padding="0"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    Clicked="BottomBarHome_Click"
                    FontSize="13"
                    Text="🏠  Home"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}" />
                <Button
                    Grid.Column="2"
                    Padding="0"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    Clicked="Settings_Click"
                    FontSize="13"
                    Text="⚙  Settings"
                    TextColor="{AppThemeBinding Dark=#888888,
                                                Light=#999999}" />
            </Grid>
        </Grid>
        <!--  ═══ Android Fandom Overlay ═══  -->
        <Grid
            x:Name="FandomOverlay"
            Grid.RowSpan="2"
            BackgroundColor="#AA000000"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="FandomOverlay_Tapped" />
            </Grid.GestureRecognizers>
            <Border
                x:Name="FandomSheet"
                Padding="16,20,16,32"
                BackgroundColor="{AppThemeBinding Dark=#1e1e1e,
                                                  Light=#f8f8f8}"
                HorizontalOptions="Fill"
                MaximumHeightRequest="520"
                StrokeShape="RoundRectangle 16,16,0,0"
                StrokeThickness="0"
                VerticalOptions="End">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <BoxView
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        BackgroundColor="{AppThemeBinding Dark=#555555,
                                                          Light=#cccccc}"
                        CornerRadius="2"
                        HeightRequest="4"
                        HorizontalOptions="Center"
                        WidthRequest="40" />
                    <Grid
                        Grid.Row="1"
                        Margin="4,0,4,12"
                        ColumnDefinitions="*,Auto">
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="Fandoms"
                            TextColor="{AppThemeBinding Dark=White,
                                                        Light=Black}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Padding="8,0"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Clicked="CloseFandomSheet_Click"
                            FontSize="18"
                            HeightRequest="44"
                            Text="✕"
                            TextColor="{AppThemeBinding Dark=#888888,
                                                        Light=#999999}"
                            WidthRequest="44" />
                    </Grid>
                    <CollectionView
                        x:Name="FandomListAndroid"
                        Grid.Row="2"
                        BackgroundColor="Transparent"
                        SelectionChanged="FandomListAndroid_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="6" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Margin="0,0,0,2"
                                    Padding="14,12"
                                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                                      Light=#ffffff}"
                                    Stroke="{AppThemeBinding Dark=#3a3a3a,
                                                             Light=#e0e0e0}"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="1">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        Text="{Binding .}"
                                        TextColor="{AppThemeBinding Dark=#dddddd,
                                                                    Light=#333333}"
                                        VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Grid
                        Grid.Row="3"
                        Margin="0,16,0,0"
                        ColumnDefinitions="*,Auto">
                        <Entry
                            x:Name="NewFandomInputAndroid"
                            BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                              Light=#ffffff}"
                            Completed="NewFandomInputAndroid_Completed"
                            Placeholder="New fandom..."
                            TextColor="{AppThemeBinding Dark=White,
                                                        Light=Black}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="0"
                            BackgroundColor="#E50914"
                            Clicked="AddFandomAndroid_Click"
                            CornerRadius="4"
                            HeightRequest="40"
                            Text="+"
                            TextColor="White"
                            WidthRequest="40" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
