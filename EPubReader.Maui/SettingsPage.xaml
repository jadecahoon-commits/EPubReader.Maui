<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EPubReader.Maui.SettingsPage"
             NavigationPage.HasNavigationBar="False">

    <Grid BackgroundColor="{AppThemeBinding Dark=#0f0f0f, Light=#f5f5f5}"
          ColumnDefinitions="Auto,*">

        <!-- ═══ Sidebar ═══ -->
        <Grid x:Name="Sidebar"
              Grid.Column="0"
              BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#e8e8e8}"
              RowDefinitions="Auto,Auto,*"
              WidthRequest="52"
              Padding="0,24,0,0">

            <!-- Toggle button -->
            <Button Grid.Row="0"
                    Text="☰"
                    Clicked="SidebarToggle_Click"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                    HorizontalOptions="Fill"
                    CornerRadius="0"
                    Padding="0,10"
                    FontSize="16"
                    HeightRequest="44" />

            <!-- Title — only visible when expanded -->
            <Label x:Name="SidebarTitleLabel"
                   Grid.Row="1"
                   Text="Settings"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Dark=White, Light=Black}"
                   HorizontalOptions="Start"
                   Margin="16,8,16,16"
                   IsVisible="False" />

            <!-- Nav items -->
            <VerticalStackLayout Grid.Row="2" Spacing="2">

                <Grid x:Name="NavAppearance"
                      ColumnDefinitions="52,*"
                      HeightRequest="48"
                      BackgroundColor="#E50914">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Sidebar_Tapped" CommandParameter="Appearance" />
                    </Grid.GestureRecognizers>
                    <Label Text="🎨" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label x:Name="NavAppearanceLabel" Grid.Column="1"
                           Text="Appearance" FontSize="13" TextColor="White"
                           VerticalOptions="Center" IsVisible="False" />
                </Grid>

                <Grid x:Name="NavLibrary"
                      ColumnDefinitions="52,*"
                      HeightRequest="48"
                      BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Sidebar_Tapped" CommandParameter="Library" />
                    </Grid.GestureRecognizers>
                    <Label Text="📚" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label x:Name="NavLibraryLabel" Grid.Column="1"
                           Text="Library" FontSize="13"
                           TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                           VerticalOptions="Center" IsVisible="False" />
                </Grid>

                <Grid x:Name="NavSync"
                      ColumnDefinitions="52,*"
                      HeightRequest="48"
                      BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Sidebar_Tapped" CommandParameter="Sync" />
                    </Grid.GestureRecognizers>
                    <Label Text="☁" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label x:Name="NavSyncLabel" Grid.Column="1"
                           Text="Sync" FontSize="13"
                           TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                           VerticalOptions="Center" IsVisible="False" />
                </Grid>

                <Grid x:Name="NavGoogleDrive"
                      ColumnDefinitions="52,*"
                      HeightRequest="48"
                      BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Sidebar_Tapped" CommandParameter="GoogleDrive" />
                    </Grid.GestureRecognizers>
                    <Label Text="🔵" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label x:Name="NavGoogleDriveLabel" Grid.Column="1"
                           Text="Google Drive" FontSize="13"
                           TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                           VerticalOptions="Center" IsVisible="False" />
                </Grid>

                <Grid x:Name="NavKindle"
                      ColumnDefinitions="52,*"
                      HeightRequest="48"
                      BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Sidebar_Tapped" CommandParameter="Kindle" />
                    </Grid.GestureRecognizers>
                    <Label Text="📧" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label x:Name="NavKindleLabel" Grid.Column="1"
                           Text="Email &amp; Kindle" FontSize="13"
                           TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                           VerticalOptions="Center" IsVisible="False" />
                </Grid>

            </VerticalStackLayout>
        </Grid>

        <!-- ═══ Content panel ═══ -->
        <ScrollView Grid.Column="1" Padding="40,32">
            <VerticalStackLayout Spacing="0">

                <!-- ── Appearance ── -->
                <VerticalStackLayout x:Name="PanelAppearance" Spacing="24" IsVisible="True">

                    <Label Text="Appearance" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=Black}" Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Reader Text" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=Black}" />
                            <Label Text="Adjust font size and text colour used while reading"
                                   FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   Margin="0,3,0,0" />
                        </VerticalStackLayout>
                        <Button x:Name="ReaderSettingsButton" Grid.Column="1"
                                Text="Aa" Clicked="ReaderSettings_Click"
                                BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e0e0e0}"
                                TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                                WidthRequest="44" HeightRequest="36" CornerRadius="4"
                                FontSize="12" Padding="0" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Dark=#2a2a2a, Light=#dddddd}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Dark Mode" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=Black}" />
                            <Label Text="Switch between light and dark interface"
                                   FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   Margin="0,3,0,0" />
                        </VerticalStackLayout>
                        <Switch x:Name="DarkModeToggle" Grid.Column="1"
                                VerticalOptions="Center" Toggled="DarkModeToggle_Toggled" />
                    </Grid>

                </VerticalStackLayout>

                <!-- ── Library ── -->
                <VerticalStackLayout x:Name="PanelLibrary" Spacing="24" IsVisible="False">

                    <Label Text="Library" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=Black}" Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Library Folder" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=Black}" />
                            <Label Text="Root folder containing your Calibre library"
                                   FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   Margin="0,3,0,0" />
                            <Label x:Name="LibraryPathLabel" FontSize="12" TextColor="#E50914"
                                   Margin="0,4,0,0" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Browse" Clicked="BrowseLibrary_Click"
                                BackgroundColor="#E50914" TextColor="White" CornerRadius="4"
                                Padding="16,8" VerticalOptions="Start" Margin="12,0,0,0" />
                    </Grid>

                </VerticalStackLayout>

                <!-- ── Sync ── -->
                <VerticalStackLayout x:Name="PanelSync" Spacing="24" IsVisible="False">

                    <Label Text="Sync" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=Black}" Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Save Data Folder" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=Black}" />
                            <Label Text="Where fandoms, categories &amp; reading positions are stored. Point this to a cloud-synced folder (OneDrive, Dropbox, etc.) to sync across devices."
                                   FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   Margin="0,3,0,0" LineBreakMode="WordWrap" />
                            <Label x:Name="SaveDataPathLabel" FontSize="12" TextColor="#E50914"
                                   Margin="0,4,0,0" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Browse" Clicked="BrowseSaveData_Click"
                                BackgroundColor="#E50914" TextColor="White" CornerRadius="4"
                                Padding="16,8" VerticalOptions="Start" Margin="12,0,0,0" />
                    </Grid>

                    <Border BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#f0f0f0}"
                            Stroke="{AppThemeBinding Dark=#333333, Light=#dddddd}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 6" Padding="14,10">
                        <Label Text="💡  Set the same Save Data Folder on each device to keep everything in sync."
                               FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                               LineBreakMode="WordWrap" />
                    </Border>

                </VerticalStackLayout>

                <!-- ── Google Drive ── -->
                <VerticalStackLayout x:Name="PanelGoogleDrive" Spacing="24" IsVisible="False">

                    <Label Text="Google Drive" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=Black}" Margin="0,0,0,8" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Sign in to upload and download library-data.json directly to your Google Drive."
                                   FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="GoogleDriveStatusLabel" FontSize="12" TextColor="#E50914"
                                   Margin="0,4,0,0" />
                            <Label x:Name="GoogleDriveLibraryLabel" FontSize="12"
                                   TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                                   Margin="0,2,0,0" />
                        </VerticalStackLayout>
                        <Button x:Name="GoogleDriveButton" Grid.Column="1"
                                Text="Sign In" Clicked="GoogleDrive_Click"
                                BackgroundColor="#4285F4" TextColor="White" CornerRadius="4"
                                Padding="16,8" VerticalOptions="Start" Margin="12,0,0,0" />
                    </Grid>

                    <Grid x:Name="GoogleDriveActionsGrid"
                          RowDefinitions="Auto,Auto,Auto" RowSpacing="8" IsVisible="False">
                        <Button Grid.Row="0" Text="⬆  Upload to Drive" Clicked="GoogleDriveUpload_Click"
                                BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                                TextColor="{AppThemeBinding Dark=White, Light=Black}"
                                CornerRadius="4" Padding="12,8" FontSize="13" HorizontalOptions="Fill" />
                        <Button Grid.Row="1" Text="⬇  Download from Drive" Clicked="GoogleDriveDownload_Click"
                                BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                                TextColor="{AppThemeBinding Dark=White, Light=Black}"
                                CornerRadius="4" Padding="12,8" FontSize="13" HorizontalOptions="Fill" />
                        <Button Grid.Row="2" Text="📁  Set Drive Library Location" Clicked="GoogleDrivePickFolder_Click"
                                BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                                TextColor="{AppThemeBinding Dark=White, Light=Black}"
                                CornerRadius="4" Padding="12,8" FontSize="13" HorizontalOptions="Fill" />
                    </Grid>

                    <Button x:Name="GoogleDriveSyncButton"
                            Text="🔄  Sync Drive Library Index" Clicked="GoogleDriveSyncLibrary_Click"
                            BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                            TextColor="{AppThemeBinding Dark=White, Light=Black}"
                            CornerRadius="4" Padding="12,8" FontSize="13" HorizontalOptions="Fill" />

                    <Label x:Name="GoogleDriveActionStatus" FontSize="12"
                           TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                           IsVisible="False" HorizontalTextAlignment="Center" />

                </VerticalStackLayout>

                <!-- ── Email & Kindle ── -->
                <VerticalStackLayout x:Name="PanelKindle" Spacing="24" IsVisible="False">

                    <Label Text="Email &amp; Kindle" FontSize="22" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=Black}" Margin="0,0,0,8" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Send-to-Kindle address" FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=Black}" />
                        <Label Text="Find this in your Amazon account under Manage Your Content and Devices → Preferences → Personal Document Settings."
                               FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                               LineBreakMode="WordWrap" />
                        <Entry x:Name="KindleEmailEntry" Placeholder="yourname@kindle.com"
                               Keyboard="Email"
                               BackgroundColor="{AppThemeBinding Dark=#1e1e1e, Light=#ffffff}"
                               TextColor="{AppThemeBinding Dark=White, Light=Black}"
                               PlaceholderColor="{AppThemeBinding Dark=#555555, Light=#aaaaaa}"
                               FontSize="14" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Button x:Name="SaveEmailButton" Text="Save" Clicked="SaveEmail_Click"
                                BackgroundColor="#E50914" TextColor="White" CornerRadius="4" Padding="20,8" />
                        <Label x:Name="EmailSaveStatusLabel" Grid.Column="1" FontSize="12"
                               TextColor="{AppThemeBinding Dark=#888888, Light=#999999}"
                               VerticalOptions="Center" IsVisible="False" />
                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
