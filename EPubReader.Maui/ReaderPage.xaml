<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EPubReader.Maui.ReaderPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="{AppThemeBinding Dark=#0f0f0f, Light=#f5f5f5}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══ Top bar ═══  -->
        <Grid Padding="20,12" BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#f0f0f0}">

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="8"
                VerticalOptions="Center">
                <!--  Reader settings  -->
                <Button
                    x:Name="ReaderSettingsButton"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                      Light=#e8e8e8}"
                    Clicked="ReaderSettings_Click"
                    CornerRadius="4"
                    FontSize="12"
                    HeightRequest="36"
                    Text="Aa"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}"
                    WidthRequest="44" />


                <!--  TOC button  -->
                <Button
                    x:Name="TocButton"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                      Light=#e8e8e8}"
                    Clicked="TocButton_Click"
                    CornerRadius="4"
                    HeightRequest="36"
                    Text="☰"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}"
                    WidthRequest="36" />

                <!--  Prev chapter (◀◀) — keyboard: Left arrow on top bar  -->
                <Button
                    x:Name="PrevChapterButton"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                      Light=#e8e8e8}"
                    Clicked="PrevChapter_Click"
                    CornerRadius="4"
                    FontSize="10"
                    HeightRequest="36"
                    Text="◀◀"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}"
                    WidthRequest="44" />

                <Label
                    x:Name="PageIndexText"
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    MaximumWidthRequest="160"
                    MinimumWidthRequest="80"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}"
                    VerticalOptions="Center" />

                <!--  Next chapter (▶▶) — keyboard: Right arrow on top bar  -->
                <Button
                    x:Name="NextChapterButton"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Dark=#2a2a2a,
                                                      Light=#e8e8e8}"
                    Clicked="NextChapter_Click"
                    CornerRadius="4"
                    FontSize="10"
                    HeightRequest="36"
                    Text="▶▶"
                    TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                Light=#555555}"
                    WidthRequest="44" />

            </HorizontalStackLayout>
        </Grid>

        <!--  ═══ Main content area ═══  -->
        <Grid Grid.Row="1">

            <!--  WebView for chapter content  -->
            <WebView
                x:Name="ContentWebView"
                Navigated="OnWebViewNavigated"
                Navigating="OnWebViewNavigating" />


            <!--  Loading overlay  -->
            <Grid
                x:Name="LoadingOverlay"
                BackgroundColor="Transparent"
                IsVisible="True">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="16"
                    VerticalOptions="Center">
                    <ActivityIndicator
                        HeightRequest="48"
                        IsRunning="True"
                        WidthRequest="48"
                        Color="#E50914" />
                    <Label
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="Opening book..."
                        TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                    Light=#555555}" />
                </VerticalStackLayout>
            </Grid>

            <!--  TOC overlay  -->
            <Grid
                x:Name="TocOverlay"
                BackgroundColor="{AppThemeBinding Dark=#000000CC,
                                                  Light=#00000066}"
                IsVisible="False">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TocOverlay_Tapped" />
                </Grid.GestureRecognizers>

                <Grid
                    BackgroundColor="{AppThemeBinding Dark=#1a1a1a,
                                                      Light=#f9f9f9}"
                    HorizontalOptions="Start"
                    RowDefinitions="Auto,*"
                    WidthRequest="300">

                    <!--  TOC header  -->
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Table of Contents"
                            TextColor="{AppThemeBinding Dark=White,
                                                        Light=Black}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Padding="0"
                            BackgroundColor="Transparent"
                            Clicked="TocClose_Click"
                            CornerRadius="4"
                            HeightRequest="32"
                            Text="✕"
                            TextColor="{AppThemeBinding Dark=#bbbbbb,
                                                        Light=#555555}"
                            WidthRequest="32" />
                    </Grid>

                    <!--  TOC list  -->
                    <CollectionView
                        x:Name="TocListView"
                        Grid.Row="1"
                        Margin="8"
                        BackgroundColor="Transparent"
                        SelectionChanged="TocListView_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10" ColumnDefinitions="Auto,*">
                                    <BoxView WidthRequest="{Binding IndentWidth}" Color="Transparent" />
                                    <Label
                                        Grid.Column="1"
                                        FontSize="13"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding Title}"
                                        TextColor="{AppThemeBinding Dark=White,
                                                                    Light=Black}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Grid>

        <!--  ═══ Status bar ═══  -->
        <Grid
            Grid.Row="2"
            Padding="20,8"
            BackgroundColor="{AppThemeBinding Dark=#1a1a1a,
                                              Light=#f0f0f0}"
            ColumnDefinitions="*,Auto">
            <Label
                x:Name="StatusText"
                Grid.Column="0"
                FontSize="11"
                LineBreakMode="TailTruncation"
                TextColor="{AppThemeBinding Dark=#888888,
                                            Light=#999999}" />
            <Label
                x:Name="ProgressText"
                Grid.Column="1"
                Margin="12,0,0,0"
                FontSize="11"
                TextColor="{AppThemeBinding Dark=#888888,
                                            Light=#999999}" />
        </Grid>
    </Grid>
</ContentPage>
