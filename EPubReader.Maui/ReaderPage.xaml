<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EPubReader.Maui.ReaderPage"
             Title="Reader">

    <Grid BackgroundColor="{AppThemeBinding Dark=#0f0f0f, Light=#f5f5f5}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Top bar ═══ -->
        <Grid BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#f0f0f0}"
              Padding="20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="8"
                                   VerticalOptions="Center">

                <!-- TOC button -->
                <Button x:Name="TocButton"
                        Text="☰"
                        Clicked="TocButton_Click"
                        BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                        TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                        WidthRequest="36" HeightRequest="36"
                        CornerRadius="4"
                        Padding="0" />

                <!-- Prev chapter (◀◀) — keyboard: Left arrow on top bar -->
                <Button x:Name="PrevChapterButton"
                        Text="◀◀"
                        Clicked="PrevChapter_Click"
                        BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                        TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                        WidthRequest="44" HeightRequest="36"
                        CornerRadius="4"
                        FontSize="10"
                        Padding="0" />

                <Label x:Name="PageIndexText"
               FontSize="12"
               TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
               VerticalOptions="Center"
               MinimumWidthRequest="80"
               MaximumWidthRequest="160"
               HorizontalTextAlignment="Center" />

                <!-- Next chapter (▶▶) — keyboard: Right arrow on top bar -->
                <Button x:Name="NextChapterButton"
                        Text="▶▶"
                        Clicked="NextChapter_Click"
                        BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                        TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                        WidthRequest="44" HeightRequest="36"
                        CornerRadius="4"
                        FontSize="10"
                        Padding="0" />

                <!-- Theme toggle -->
                <Button x:Name="ThemeButton"
                        Text="◑"
                        Clicked="ThemeButton_Click"
                        InputTransparent="False"
                        BackgroundColor="{AppThemeBinding Dark=#2a2a2a, Light=#e8e8e8}"
                        TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                        WidthRequest="36" HeightRequest="36"
                        CornerRadius="4"
                        Padding="0" />
            </HorizontalStackLayout>
        </Grid>

        <!-- ═══ Main content area ═══ -->
        <Grid Grid.Row="1">

            <!-- WebView for chapter content -->
            <WebView x:Name="ContentWebView"
                     Navigating="OnWebViewNavigating"
                     Navigated="OnWebViewNavigated" />

            <!--
                Invisible tap zones — sit on top of the WebView.
                Left half → prev page, Right half → next page.
                These handle Android touch and also desktop mouse clicks
                that the WebView JS might miss (e.g. on link elements).
                They are InputTransparent except for the tap gesture itself,
                so text selection etc. still work in the WebView.
                Width is set to 15% of screen so they don't eat too much content.
            <Grid ColumnDefinitions="0.15*,0.7*,0.15*"
                  InputTransparent="True">

                <BoxView Grid.Column="0"
                         Color="Transparent"
                         InputTransparent="False">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="LeftTap_Tapped" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <BoxView Grid.Column="1"
                         Color="Transparent"
                         InputTransparent="True" />

                <BoxView Grid.Column="2"
                         Color="Transparent"
                         InputTransparent="False">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="RightTap_Tapped" />
                    </BoxView.GestureRecognizers>
                </BoxView>
        </Grid>
        -->

        <!-- Loading overlay -->
            <Grid x:Name="LoadingOverlay"
                  BackgroundColor="Transparent"
                  IsVisible="True">
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="16">
                    <ActivityIndicator IsRunning="True"
                                       WidthRequest="48"
                                       HeightRequest="48"
                                       Color="#E50914" />
                    <Label Text="Opening book..."
                           FontSize="14"
                           TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- TOC overlay -->
            <Grid x:Name="TocOverlay"
                  IsVisible="False"
                  BackgroundColor="{AppThemeBinding Dark=#000000CC, Light=#00000066}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TocOverlay_Tapped" />
                </Grid.GestureRecognizers>

                <Grid HorizontalOptions="Start"
                      WidthRequest="300"
                      BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#f9f9f9}"
                      RowDefinitions="Auto,*">

                    <!-- TOC header -->
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <Label Text="Table of Contents"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=Black}"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                Clicked="TocClose_Click"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Dark=#bbbbbb, Light=#555555}"
                                WidthRequest="32" HeightRequest="32"
                                CornerRadius="4"
                                Padding="0" />
                    </Grid>

                    <!-- TOC list -->
                    <CollectionView x:Name="TocListView"
                                    Grid.Row="1"
                                    SelectionMode="Single"
                                    SelectionChanged="TocListView_SelectionChanged"
                                    BackgroundColor="Transparent"
                                    Margin="8">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10" ColumnDefinitions="Auto,*">
                                    <BoxView WidthRequest="{Binding IndentWidth}"
                                             Color="Transparent" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Dark=White, Light=Black}"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ Status bar ═══ -->
        <Grid Grid.Row="2"
              BackgroundColor="{AppThemeBinding Dark=#1a1a1a, Light=#f0f0f0}"
              Padding="20,8">
            <Label x:Name="StatusText"
                   FontSize="11"
                   TextColor="{AppThemeBinding Dark=#888888, Light=#999999}" />
        </Grid>
    </Grid>
</ContentPage>
