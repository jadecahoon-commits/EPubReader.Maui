<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:EPubReader.Maui"
       x:Class="EPubReader.Maui.AppShell">

    <!-- HomePage is the opening screen -->
    <ShellContent Route="HomePage"
                  ContentTemplate="{DataTemplate local:HomePage}" />

    <!-- MainPage and SettingsPage are navigated to from HomePage -->
    <ShellContent Route="MainPage"
                  ContentTemplate="{DataTemplate local:MainPage}"
                  IsVisible="False" />

    <ShellContent Route="SettingsPage"
                  ContentTemplate="{DataTemplate local:SettingsPage}"
                  IsVisible="False" />

</Shell>
